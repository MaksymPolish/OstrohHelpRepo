{
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=5432;Database=OstrohHelp-DB;User Id=postgres;Password=postgres;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Enabled": true,
    "Endpoints": {
      "SendMessage": {
        "MaxRequests": 100,
        "WindowSeconds": 60
      },
      "BatchUpload": {
        "MaxRequests": 10,
        "WindowSeconds": 60
      },
      "DeleteMessage": {
        "MaxRequests": 50,
        "WindowSeconds": 60
      },
      "DeleteAttachment": {
        "MaxRequests": 50,
        "WindowSeconds": 60
      }
    }
  }
}
