# ============================================
# FRONTEND (.env) - OstrohHelp Web
# ============================================

# React App Configuration
# ========================

# API Endpoint
# For local development: http://api:8080 (docker-compose) or http://localhost:8080
# For production EC2: http://ostrohelpapi-app:8080 (same network) or http://your-domain.com
REACT_APP_API_URL=http://api:8080

# Google OAuth
# Get your credentials from: https://console.cloud.google.com/
REACT_APP_GOOGLE_CLIENT_ID={Your-Google-Client-ID}

# Mock Authentication (for testing without backend)
# Set to false for real authentication
REACT_APP_USE_MOCK_AUTH=false

# ============================================
# BACKEND (.env) - OstrohHelp API
# Only needed if running backend in docker-compose.yml
# ============================================

ASPNETCORE_ENVIRONMENT=Development

# Database Connection
# For local docker-compose: postgres container
# For EC2 production: your actual database host
ConnectionStrings__Default=Host=postgres;Port=5432;Database=ostrohelpdb;Username=ostrohelpuser;Password=OstroHelpPass123!

# Data Protection
Encryption__MasterKey={Your-256-bit-Base64-Encoded-Key} # Generate a secure key for production

# JWT Configuration
JWT_SECRET=SecureJWTSecretKeyForHS256AlgorithmWith256BitsMinimumLength1234567890
JWT_ISSUER=https://securetoken.google.com/ostrohhelpapp-e9a56
JWT_AUDIENCE={Your-Google-OAuth-Audience}

# Google OAuth (Backend)
GOOGLE_CLIENT_ID={Your-Google-Client-ID}
GOOGLE_CLIENT_SECRET={Your-Google-Client-Secret}

# Cloudinary Configuration (File uploads)
CLOUDINARY_API_KEY={Your-Cloudinary-API-Key}
CLOUDINARY_API_SECRET={Your-Cloudinary-API-Secret}
CLOUDINARY_CLOUD_NAME={Your-Cloudinary-Cloud-Name}

# ============================================
# DATABASE
# ============================================

POSTGRES_USER={Your-Database-Username}
POSTGRES_PASSWORD={Your-Database-Password}
POSTGRES_DB=ostrohelpdb
